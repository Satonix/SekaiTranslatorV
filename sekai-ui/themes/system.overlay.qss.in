QWidget#mainBackgroundHost,
QSplitter,
QSplitter::handle,
QWidget#fileTabSurface,
QWidget#editorPanel,
QWidget#originalEditorSurface,
QWidget#translationEditorSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QStackedWidget,
QStackedWidget > QWidget,
QFrame {
    background: transparent;
}

QWidget#projectTreePanel,
QWidget#fileTabSurface,
QWidget#editorPanel,
QWidget#originalSection,
QWidget#translationSection,
QWidget#originalEditorSurface,
QWidget#translationEditorSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QStackedWidget,
QStackedWidget > QWidget,
QFrame,
QGroupBox {
    background-color: rgba(236, 240, 246, {{PANEL_ALPHA}});
    border-color: rgba(130, 142, 160, {{BORDER_ALPHA}});
}

QAbstractScrollArea,
QListView {
    background: transparent;
    border-color: rgba(140, 148, 162, {{BORDER_ALPHA}});
}

QTableView {
    background: transparent;
    alternate-background-color: rgba(238, 243, 248, {{ALT_ROW_ALPHA}});
}

QTableView::item {
    background: transparent;
}

QTableView::item:alternate {
    background-color: rgba(238, 243, 248, {{ALT_ROW_ALPHA}});
}

QTreeView,
QWidget#originalEditorGutter,
QWidget#translationEditorGutter,
QHeaderView,
QHeaderView::section,
QAbstractScrollArea > QWidget[sekaiOverlayViewport="true"],
QWidget[sekaiOverlayViewport="true"],
QWidget[sekaiOverlayInner="true"] {
    background-color: rgba(242, 246, 252, {{VIEWPORT_ALPHA}});
    border-color: rgba(130, 142, 160, {{BORDER_ALPHA}});
}

QTabBar::tab {
    background-color: rgba(237, 242, 248, {{TAB_ALPHA}});
    border-color: rgba(130, 142, 160, {{BORDER_STRONG_ALPHA}});
}

QTabBar::tab:selected {
    background-color: rgba(250, 252, 255, {{TAB_SELECTED_ALPHA}});
    border-color: rgba(72, 125, 209, {{BORDER_FOCUS_ALPHA}});
}

QLineEdit,
QComboBox,
QSpinBox,
QDoubleSpinBox,
QPushButton,
QToolButton {
    background-color: rgba(250, 252, 255, {{INPUT_ALPHA}});
    border-color: rgba(130, 142, 160, {{BORDER_STRONG_ALPHA}});
}

QMenuBar,
QMenu,
QStatusBar {
    background-color: rgba(244, 247, 252, {{MENU_ALPHA}});
}

QPlainTextEdit#originalEditor,
QPlainTextEdit#translationEditor,
QTextEdit {
    background-color: rgba(248, 250, 253, {{VIEWPORT_ALPHA}});
}


QTabBar QToolButton,
QTabWidget QToolButton {
    background: palette(button);
    color: palette(button-text);
    border: 1px solid palette(mid);
}

QTabBar QToolButton:hover,
QTabWidget QToolButton:hover {
    background: palette(light);
}

QTabBar QToolButton:pressed,
QTabWidget QToolButton:pressed,
QTabBar QToolButton:checked,
QTabWidget QToolButton:checked {
    background: palette(midlight);
}

QTabBar::scroller {
    background: transparent;
}
