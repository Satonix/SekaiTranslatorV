QWidget {
    font-size: 10pt;
    color: #1f2937;
    selection-background-color: #cfe3ff;
    selection-color: #111827;
}

QMainWindow, QDialog {
    background-color: #f4f7fb;
}

QLabel[sectionLabel="true"],
QLabel#sectionHeader,
QLabel[titleLabel="true"] {
    color: #111827;
    font-weight: 700;
}

QLabel[mutedText="true"] {
    color: #667085;
}

QMenuBar {
    background-color: #eef2f7;
    border-bottom: 1px solid #cfd8e3;
    color: #1f2937;
}

QMenuBar::item {
    background: transparent;
    padding: 6px 10px;
}

QMenuBar::item:selected {
    background-color: #dbeafe;
    color: #111827;
}

QMenu {
    background-color: #ffffff;
    border: 1px solid #cfd8e3;
    color: #1f2937;
}

QMenu::item {
    background-color: #ffffff;
    padding: 6px 10px;
}

QMenu::item:selected {
    background-color: #f3f7fd;
    color: #111827;
}

QStatusBar {
    background-color: #eef2f7;
    border-top: 1px solid #cfd8e3;
    color: #1f2937;
}

QToolTip {
    background-color: #ffffff;
    color: #111827;
    border: 1px solid #b8c4d6;
}

QWidget#projectTreePanel,
QTabWidget#mainTabs {
    background-color: #ffffff;
    border: 1px solid #d0d7e2;
    border-radius: 3px;
}

QTreeView,
QTableView,
QPlainTextEdit,
QTextEdit,
QListWidget,
QTabWidget::pane,
QAbstractScrollArea,
QFrame {
    background-color: #ffffff;
    border: 0px;
    border-radius: 0px;
}

QLineEdit,
QComboBox,
QSpinBox,
QDoubleSpinBox {
    background-color: #ffffff;
    border: 1px solid #d0d7e2;
    border-radius: 3px;
}

QGroupBox {
    background-color: transparent;
    border: 1px solid #d0d7e2;
    border-radius: 3px;
    margin-top: 10px;
    padding-top: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 8px;
    padding: 0 4px;
    color: #1d4ed8;
    font-weight: 700;
}

QTreeView::branch:selected,
QListWidget::item:selected,
QTreeView::item:selected,
QTableView::item:selected {
    background-color: #cfe3ff;
    color: #111827;
}

QHeaderView::section {
    background-color: #f7f9fc;
    color: #111827;
    border: none;
    border-right: 1px solid #d0d7e2;
    border-bottom: 1px solid #d0d7e2;
    padding: 6px 8px;
    font-weight: 600;
}

QPushButton {
    background-color: #f8fafc;
    color: #1f2937;
    border: 1px solid #cfd8e3;
    border-radius: 3px;
    padding: 6px 12px;
}

QPushButton:hover,
QComboBox:hover,
QLineEdit:hover,
QPlainTextEdit:hover,
QTextEdit:hover,
QListWidget:hover,
QTreeView:hover,
QTableView:hover {
    border-color: #3b82f6;
}

QPushButton:pressed {
    background-color: #eef2f7;
}

QPushButton:disabled,
QComboBox:disabled,
QLineEdit:disabled,
QPlainTextEdit:disabled,
QTextEdit:disabled {
    color: #98a2b3;
    border-color: #d9e1ea;
    background-color: #f5f7fa;
}

QComboBox::drop-down {
    width: 22px;
    border-left: 1px solid #d0d7e2;
}

QTabWidget::pane {
    margin-top: -1px;
}

QTabBar::tab {
    background-color: #eef2f7;
    color: #334155;
    border: 1px solid #d0d7e2;
    padding: 7px 12px;
    margin-right: 2px;
    min-width: 110px;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
}

QTabBar::tab:selected {
    background-color: #ffffff;
    color: #111827;
    border-bottom-color: #3b82f6;
}

QTabBar::tab:!selected {
    margin-top: 2px;
}

QCheckBox, QRadioButton {
    color: #1f2937;
    spacing: 8px;
}

QCheckBox::indicator,
QRadioButton::indicator {
    width: 14px;
    height: 14px;
}

QScrollBar:vertical, QScrollBar:horizontal {
    background: #f1f5f9;
    border: none;
    margin: 0px;
}

QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: #cbd5e1;
    min-height: 20px;
    min-width: 20px;
    border-radius: 3px;
}

QScrollBar::add-line, QScrollBar::sub-line,
QScrollBar::add-page, QScrollBar::sub-page {
    background: none;
    border: none;
}

QWidget#editorPanel {
    background-color: transparent;
}

QWidget#originalSection,
QWidget#translationSection {
    background-color: #ffffff;
    border: 0px;
}

QWidget#translationSection {
    background-color: #f8fbff;
}

QLabel#originalSectionLabel,
QLabel#translationSectionLabel {
    padding: 4px 8px;
    background-color: #f7f9fc;
    border-bottom: 1px solid #d0d7e2;
    color: #111827;
    font-weight: 700;
}

QLabel#translationSectionLabel {
    background-color: #eef4ff;
}

QWidget#originalEditorSurface,
QWidget#translationEditorSurface {
    background-color: transparent;
    border: 0px;
}

QPlainTextEdit#originalEditor,
QPlainTextEdit#translationEditor {
    border: 0px;
    padding: 0px 6px 0px 6px;
}

QPlainTextEdit#originalEditor {
    background-color: #ffffff;
}

QPlainTextEdit#translationEditor {
    background-color: #f8fbff;
}

QSplitter#editorSplitter::handle:vertical {
    background-color: transparent;
    height: 10px;
    margin: 0 4px;
    border-top: 1px solid #d0d7e2;
}

QWidget#originalEditorGutter,
QWidget#translationEditorGutter {
    background-color: #f7f9fc;
    border-right: 1px solid #d0d7e2;
}

QWidget#originalEditorGutter,
QWidget#translationEditorGutter,
QWidget#originalEditorGutter QLabel,
QWidget#translationEditorGutter QLabel {
    color: #64748b;
}

QTabBar QToolButton,
QTabWidget QToolButton {
    background-color: #f4f7fb;
    color: #283646;
    border: 1px solid #c9d4df;
    padding: 4px 8px;
}

QTabBar QToolButton:hover,
QTabWidget QToolButton:hover {
    background-color: #ffffff;
    border-color: #9eb2c7;
}

QTabBar QToolButton:pressed,
QTabWidget QToolButton:pressed,
QTabBar QToolButton:checked,
QTabWidget QToolButton:checked {
    background-color: #e7eef7;
    border-color: #6e96c7;
}

QTabBar::scroller {
    background: transparent;
}