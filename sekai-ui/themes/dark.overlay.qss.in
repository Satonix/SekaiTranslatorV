QWidget#mainBackgroundHost,
QSplitter,
QSplitter::handle,
QWidget#fileTabSurface,
QWidget#editorPanel,
QWidget#originalEditorSurface,
QWidget#translationEditorSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QStackedWidget,
QStackedWidget > QWidget,
QFrame {
    background: transparent;
}

QWidget#projectTreePanel,
QWidget#fileTabSurface,
QWidget#editorPanel,
QWidget#originalSection,
QWidget#translationSection,
QWidget#originalEditorSurface,
QWidget#translationEditorSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QStackedWidget,
QStackedWidget > QWidget,
QFrame,
QGroupBox {
    background-color: rgba(28, 31, 36, {{PANEL_ALPHA}});
    border-color: rgba(107, 114, 128, {{BORDER_ALPHA}});
}

QWidget#projectTreePanel,
QWidget#fileTabSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QGroupBox {
    border-color: rgba(107, 114, 128, {{BORDER_STRONG_ALPHA}});
}

QAbstractScrollArea,
QListView {
    background: transparent;
    border-color: rgba(107, 114, 128, {{BORDER_ALPHA}});
}

QTableView {
    background: transparent;
    alternate-background-color: rgba(52, 59, 69, {{ALT_ROW_ALPHA}});
}

QTableView::item {
    background: transparent;
}

QTableView::item:alternate {
    background-color: rgba(52, 59, 69, {{ALT_ROW_ALPHA}});
}

QTreeView,
QWidget#originalEditorGutter,
QWidget#translationEditorGutter,
QHeaderView,
QHeaderView::section {
    background-color: rgba(43, 49, 59, {{GUTTER_ALPHA}});
    border-color: rgba(107, 114, 128, {{BORDER_ALPHA}});
}

QAbstractScrollArea > QWidget[sekaiOverlayViewport="true"],
QWidget[sekaiOverlayViewport="true"],
QWidget[sekaiOverlayInner="true"] {
    background-color: rgba(39, 44, 52, {{VIEWPORT_ALPHA}});
    border: none;
}

QTabBar,
QTabBar::tab-bar {
    background: transparent;
}

QTabBar::tab {
    background-color: rgba(43, 49, 59, {{TAB_ALPHA}});
    border-color: rgba(107, 114, 128, {{BORDER_STRONG_ALPHA}});
}

QTabBar::tab:selected {
    background-color: rgba(55, 65, 81, {{TAB_SELECTED_ALPHA}});
    border-color: rgba(209, 213, 219, {{BORDER_FOCUS_ALPHA}});
}

QTabBar::tab:!selected:hover {
    background-color: rgba(49, 57, 68, {{TAB_HOVER_ALPHA}});
    border-color: rgba(156, 163, 175, {{BORDER_HOVER_ALPHA}});
}

QLineEdit,
QComboBox,
QSpinBox,
QDoubleSpinBox,
QPushButton,
QToolButton {
    background-color: rgba(43, 49, 59, {{INPUT_ALPHA}});
    border-color: rgba(107, 114, 128, {{BORDER_STRONG_ALPHA}});
}

QLineEdit:hover,
QComboBox:hover,
QSpinBox:hover,
QDoubleSpinBox:hover,
QPushButton:hover,
QToolButton:hover {
    border-color: rgba(209, 213, 219, {{BORDER_FOCUS_ALPHA}});
}

QSplitter::handle {
    background-color: rgba(39, 44, 52, {{SPLITTER_ALPHA}});
}

QMenuBar,
QMenu,
QStatusBar {
    background-color: rgba(31, 35, 41, {{MENU_ALPHA}});
}

QPlainTextEdit#originalEditor,
QPlainTextEdit#translationEditor,
QTextEdit {
    background-color: rgba(39, 44, 52, {{VIEWPORT_ALPHA}});
}

QTabBar::scroller {
    background: transparent;
}