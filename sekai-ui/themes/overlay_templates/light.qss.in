QWidget#mainBackgroundHost,
QSplitter,
QSplitter::handle,
QWidget#fileTabSurface,
QWidget#editorPanel,
QWidget#originalEditorSurface,
QWidget#translationEditorSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QStackedWidget,
QStackedWidget > QWidget,
QFrame {
    background: transparent;
}

QWidget#projectTreePanel,
QWidget#fileTabSurface,
QWidget#editorPanel,
QWidget#originalSection,
QWidget#translationSection,
QWidget#originalEditorSurface,
QWidget#translationEditorSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QStackedWidget,
QStackedWidget > QWidget,
QFrame,
QGroupBox {
    background-color: rgba(250, 252, 255, {{PANEL_ALPHA}});
    border-color: rgba(145, 156, 171, {{BORDER_ALPHA}});
}

QWidget#projectTreePanel,
QWidget#fileTabSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QGroupBox {
    border-color: rgba(130, 146, 166, {{BORDER_STRONG_ALPHA}});
}

QAbstractScrollArea,
QTableView,
QPlainTextEdit#originalEditor,
QPlainTextEdit#translationEditor,
QListView,
QTextEdit {
    background: transparent;
    border-color: rgba(145, 156, 171, {{BORDER_ALPHA}});
}

QTableView {
    alternate-background-color: rgba(241, 246, 252, {{ALT_ROW_ALPHA}});
}

QTreeView,
QWidget#originalEditorGutter,
QWidget#translationEditorGutter,
QHeaderView,
QHeaderView::section {
    background-color: rgba(244, 248, 253, {{GUTTER_ALPHA}});
    border-color: rgba(145, 156, 171, {{BORDER_ALPHA}});
}

QWidget[sekaiOverlayViewport="true"],
QWidget[sekaiOverlayInner="true"] {
    background-color: rgba(255, 255, 255, {{VIEWPORT_ALPHA}});
    border: none;
}

QTabBar,
QTabBar::tab-bar {
    background: transparent;
}

QTabBar::tab {
    background-color: rgba(242, 246, 251, {{TAB_ALPHA}});
    border-color: rgba(130, 146, 166, {{BORDER_STRONG_ALPHA}});
}

QTabBar::tab:selected {
    background-color: rgba(255, 255, 255, {{TAB_SELECTED_ALPHA}});
    border-color: rgba(72, 125, 209, {{BORDER_FOCUS_ALPHA}});
}

QTabBar::tab:!selected:hover {
    background-color: rgba(247, 250, 255, {{TAB_HOVER_ALPHA}});
    border-color: rgba(130, 146, 166, {{BORDER_HOVER_ALPHA}});
}

QLineEdit,
QComboBox,
QSpinBox,
QDoubleSpinBox,
QPushButton,
QToolButton {
    background-color: rgba(255, 255, 255, {{INPUT_ALPHA}});
    border-color: rgba(130, 146, 166, {{BORDER_STRONG_ALPHA}});
}

QLineEdit:hover,
QComboBox:hover,
QSpinBox:hover,
QDoubleSpinBox:hover,
QPushButton:hover,
QToolButton:hover {
    border-color: rgba(72, 125, 209, {{BORDER_FOCUS_ALPHA}});
}

QSplitter::handle {
    background-color: rgba(235, 241, 248, {{SPLITTER_ALPHA}});
}

QMenuBar,
QMenu,
QStatusBar {
    background-color: rgba(247, 250, 254, {{MENU_ALPHA}});
}
