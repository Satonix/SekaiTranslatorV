QWidget#mainBackgroundHost,
QSplitter,
QSplitter::handle,
QWidget#fileTabSurface,
QWidget#editorPanel,
QWidget#originalEditorSurface,
QWidget#translationEditorSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QStackedWidget,
QStackedWidget > QWidget,
QFrame {
    background: transparent;
}

QWidget#projectTreePanel,
QWidget#fileTabSurface,
QWidget#editorPanel,
QWidget#originalSection,
QWidget#translationSection,
QWidget#originalEditorSurface,
QWidget#translationEditorSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QStackedWidget,
QStackedWidget > QWidget,
QFrame,
QGroupBox {
    background-color: rgba(255, 255, 255, {{PANEL_ALPHA}});
    border-color: rgba(59, 130, 246, {{BORDER_ALPHA}});
}

QWidget#projectTreePanel,
QWidget#fileTabSurface,
QTabWidget#mainTabs,
QTabWidget#mainTabs::pane,
QGroupBox {
    border-color: rgba(59, 130, 246, {{BORDER_STRONG_ALPHA}});
}

QAbstractScrollArea,
QListView {
    background: transparent;
    border-color: rgba(59, 130, 246, {{BORDER_ALPHA}});
}

QTableView {
    background: transparent;
    alternate-background-color: rgba(241, 245, 249, {{ALT_ROW_ALPHA}});
}

QTableView::item {
    background: transparent;
}

QTableView::item:alternate {
    background-color: rgba(241, 245, 249, {{ALT_ROW_ALPHA}});
}

QTreeView,
QWidget#originalEditorGutter,
QWidget#translationEditorGutter,
QHeaderView,
QHeaderView::section {
    background-color: rgba(248, 250, 252, {{GUTTER_ALPHA}});
    border-color: rgba(59, 130, 246, {{BORDER_ALPHA}});
}

QAbstractScrollArea > QWidget[sekaiOverlayViewport="true"],
QWidget[sekaiOverlayViewport="true"],
QWidget[sekaiOverlayInner="true"] {
    background-color: rgba(255, 255, 255, {{VIEWPORT_ALPHA}});
    border: none;
}

QTabBar,
QTabBar::tab-bar {
    background: transparent;
}

QTabBar::tab {
    background-color: rgba(248, 250, 252, {{TAB_ALPHA}});
    border-color: rgba(59, 130, 246, {{BORDER_STRONG_ALPHA}});
}

QTabBar::tab:selected {
    background-color: rgba(239, 246, 255, {{TAB_SELECTED_ALPHA}});
    border-color: rgba(37, 99, 235, {{BORDER_FOCUS_ALPHA}});
}

QTabBar::tab:!selected:hover {
    background-color: rgba(243, 244, 246, {{TAB_HOVER_ALPHA}});
    border-color: rgba(59, 130, 246, {{BORDER_HOVER_ALPHA}});
}

QLineEdit,
QComboBox,
QSpinBox,
QDoubleSpinBox,
QPushButton,
QToolButton {
    background-color: rgba(255, 255, 255, {{INPUT_ALPHA}});
    border-color: rgba(59, 130, 246, {{BORDER_STRONG_ALPHA}});
}

QLineEdit:hover,
QComboBox:hover,
QSpinBox:hover,
QDoubleSpinBox:hover,
QPushButton:hover,
QToolButton:hover {
    border-color: rgba(37, 99, 235, {{BORDER_FOCUS_ALPHA}});
}

QSplitter::handle {
    background-color: rgba(226, 232, 240, {{SPLITTER_ALPHA}});
}

QMenuBar,
QMenu,
QStatusBar {
    background-color: rgba(255, 255, 255, {{MENU_ALPHA}});
}

QPlainTextEdit#originalEditor,
QPlainTextEdit#translationEditor,
QTextEdit {
    background-color: rgba(255, 255, 255, {{VIEWPORT_ALPHA}});
}

QTabBar::scroller {
    background: transparent;
}